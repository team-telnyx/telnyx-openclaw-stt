{
  "name": "telnyx-stt",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "description": "Telnyx STT provider for OpenClaw audio transcription",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "2026.4"
    },
    "build": {
      "openclawVersion": "2026.4.24"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "telnyx",
    "stt",
    "speech-to-text",
    "audio",
    "transcription"
  ],
  "author": "Ifthikar Razik <ifthikar@telnyx.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/team-telnyx/telnyx-openclaw-stt.git"
  },
  "bugs": {
    "url": "https://github.com/team-telnyx/telnyx-openclaw-stt/issues"
  },
  "homepage": "https://github.com/team-telnyx/telnyx-openclaw-stt#readme",
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "devDependencies": {
    "openclaw": "^2026.4.24",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}